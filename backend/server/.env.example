# Whisper/OpenAI-compatible transcription settings
# For OpenAI native Whisper:
# WHISPER_API_BASE=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1
# WHISPER_API_KEY=sk-...

# For Groq OpenAI-compatible transcription:
WHISPER_API_BASE=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_API_KEY=
