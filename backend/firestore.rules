rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function role() { return request.auth.token.role; }
    function schoolId() { return request.auth.token.schoolId; }

    match /schools/{sid}/{document=**} {
      allow read: if request.auth != null && schoolId() == sid;
      allow write: if request.auth != null && schoolId() == sid && (role() in ['super_admin','incharge']);
    }
  }
}
